# App Settings
USER_FULL_NAME="Tu Nombre Completo"
USER_ACCOUNT_NUMBER="tu_numero_cuenta"

# JWT Settings (Shared with API Gateway)
JWT_SECRET_KEY="tu_clave_secreta_jwt"
JWT_ALGORITHM="HS256"

# Database Settings
DATABASE_URL="sqlite:///./app/data/personal_finances.db"

# AI Settings (elige un proveedor: openai | ollama | gemini)
AI_PROVIDER="openai"
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llava"
GEMINI_MODEL="gemini-3.1-flash-lite"
GEMINI_API_KEY="..."

# File Upload Settings
MAX_FILE_SIZE_MB=10
UPLOAD_DIR="./app/data/uploads"

# MarkItDown Settings
USE_MARKITDOWN=True
MARKITDOWN_MIN_CHARS=50
